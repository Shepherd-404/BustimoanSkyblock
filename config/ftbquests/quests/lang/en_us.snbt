	quest.4B0DBC05C9565B39.quest_desc: [
		"The Thermoelectric Generator is a power generation block.  It generates RF based on the temperature difference of the blocks surrounding it. "
		""
		"It lacks an internal buffer, so you don't see any RF when looking at it. "
		""
		"TIP: you need 20 Thermoelectric Generator blocks if you plan to use them as the single powersource to automate "
	]
	quest.4B0DBC05C9565B39.quest_subtitle: "...feel free to scale!"
